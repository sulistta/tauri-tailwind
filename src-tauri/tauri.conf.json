{
  "build": {
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "Site2React",
  "mainBinaryName": "site2react",
  "version": "0.1.0",
  "identifier": "com.site2react.app",
  "plugins": {
    "shell": {
      "open": "((mailto:\\w+)|(tel:\\w+)|(https?://\\w+).+|(/.+)|([A-Za-z]:\\\\.+))"
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Site2React",
        "width": 1320,
        "height": 860,
        "useHttpsScheme": true
      }
    ]
  }
}
